@namespace OutlookPlugin.Components.Layout
@using OutlookPlugin.Services
@inject AppState AppState

<div class="flex flex-col min-h-screen bg-neutral-lighter">
    <Header />

    @if (IsAuthenticated && ShowCopilot && AppState.DiscoveredContacts.Any())
    {
        <CopilotPanel />
    }

    @if (IsAuthenticated && ShowTabs)
    {
        <TabNavigation />
    }

    <main class="flex-1 overflow-y-auto">
        @ChildContent
    </main>
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public bool ShowTabs { get; set; } = true;
    [Parameter] public bool ShowCopilot { get; set; } = true;

    private bool IsAuthenticated => AppState.AuthStatus == AuthStatus.Authenticated;

    protected override void OnInitialized()
    {
        AppState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        AppState.OnChange -= StateHasChanged;
    }
}
